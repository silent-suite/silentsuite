{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "silentsuite",
  "main": "apps/landing/.open-next/worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "apps/landing/.open-next/assets",
    "binding": "ASSETS"
  }
  // N8N_CONFIRM_WEBHOOK_URL is set as a secret via:
  // npx wrangler secret put N8N_CONFIRM_WEBHOOK_URL
}
