    <item android:state_focused="true" android:color="@color/teal600" />
    <item android:state_hovered="true" android:color="@color/teal600" />
    <item android:state_enabled="true" android:color="@color/navy700" />
    <item android:color="@android:color/darker_gray" />
</selector>
