# SilentSuite Self-Hosted Configuration
# Copy this file to .env and fill in your values.
# Or run ./install.sh to generate everything automatically.

# Port the SilentSuite server listens on (default: 3735).
# Your reverse proxy should forward traffic to this port.
SERVER_PORT=3735

# PostgreSQL password (auto-generated by install.sh)
DATABASE_PASSWORD=

# Admin credentials for the admin panel at http://localhost:3735/admin/
SUPER_USER=admin
SUPER_PASS=
