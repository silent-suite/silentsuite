# SilentSuite Self-Hosted Configuration
# Copy this file to .env and fill in your values.
# Or run ./install.sh to generate everything automatically.

# Your domain name. The SilentSuite server will be available at https://DOMAIN
# Point a DNS A record for this domain to your server's IP.
DOMAIN=sync.example.com

# PostgreSQL password (auto-generated by install.sh)
DATABASE_PASSWORD=

# Admin credentials for the Django admin panel at https://DOMAIN/admin/
SUPER_USER=admin
SUPER_PASS=
