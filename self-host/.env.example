# SilentSuite Self-Hosted Configuration
# Copy this file to .env and fill in your values

# Your domain name (e.g., silentsuite.example.com)
DOMAIN=

# Database password for PostgreSQL (auto-generated by install.sh)
POSTGRES_PASSWORD=

# Etebase database user password (auto-generated by install.sh)
ETEBASE_DB_PASSWORD=

# Etebase Django admin credentials
ETEBASE_ADMIN_USER=admin
ETEBASE_ADMIN_PASSWORD=
