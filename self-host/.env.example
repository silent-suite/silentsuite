# SilentSuite Self-Hosted Configuration
# Copy this file to .env and fill in your values.
# Or run the installer to generate everything automatically:
#   curl -fsSL https://raw.githubusercontent.com/silent-suite/silentsuite/main/self-host/install.sh | bash

# Port the SilentSuite server listens on (default: 3735).
# Your reverse proxy should forward traffic to this port.
SERVER_PORT=3735

# PostgreSQL password (auto-generated by install.sh)
DATABASE_PASSWORD=

# Django admin panel credentials (advanced use only).
# These are for the Etebase Django admin at https://YOUR_DOMAIN/admin/
# Most users don't need this — the first user to sign up in the
# SilentSuite app becomes the server admin automatically.
SUPER_USER=admin
SUPER_PASS=

# Comma-separated list of hostnames the server will accept.
# Set this to your domain (e.g., sync.example.com).
# Include localhost if you also want local access for testing.
ALLOWED_HOSTS=sync.example.com,localhost
