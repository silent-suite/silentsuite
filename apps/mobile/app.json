{
  "expo": {
    "name": "SilentSuite",
    "slug": "silensuite",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "silentsuite",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2838"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.silentsuite.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "SilentSuite needs access to your calendar to sync your encrypted events.",
        "NSContactsUsageDescription": "SilentSuite needs access to your contacts to sync your encrypted address book.",
        "NSRemindersUsageDescription": "SilentSuite needs access to your reminders to sync your encrypted tasks."
      }
    },
    "android": {
      "package": "io.silentsuite.app",
      "adaptiveIcon": {
        "backgroundColor": "#1B2838",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-calendar",
      "expo-contacts",
      "expo-background-fetch",
      "expo-task-manager",
      "@react-native-community/datetimepicker",
      "./plugins/withSyncAdapter"
    ],
    "extra": {
      "eas": {
        "projectId": "d4f93279-0b18-4dd8-8d90-c03f8241c57c"
      }
    },
    "owner": "silentsuite"
  }
}
